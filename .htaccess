<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files/directories from the root as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Forward everything else to /public (keeps Laravel defaults intact)
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

